generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String?
  password  String
  role      String   @default("reporter")
  category  String?
  status    String   @default("Active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lastLogin DateTime?
}

model Article {
  id              String   @id @default(uuid())
  title           String
  content         String
  status          String   @default("draft")
  createdAt       DateTime @default(now())
  author          String?
  featuredImg     String?
  sourceLink      String?
  tags            String[]
  category        String?
  socialPostUrls  String[]
  socialVideoUrls String[]
}

model Media {
  id           String   @id @default(cuid())
  url          String
  publicId     String?
  createdAt    DateTime @default(now())
  category     String?
  isFeatured   Boolean  @default(false)
  name         String?
  type         String?
  altText      String?
  articleId    String?
  articleTitle String?
  caption      String?
  fileSize     Int?
}

model Category {
  id          String   @id @default(uuid())
  name        String
  slug        String
  parent      String   @default("None")
  description String   @default("")
  count       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Tag {
  id          String   @id @default(uuid())
  name        String   @unique
  slug        String   @unique
  description String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Place {
  id          Int      @id @default(autoincrement())
  name        String
  slug        String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  description String?
  image       String?
  location    String?
  author      String?
  status      String   @default("draft")
}

model Pincode {
  id          String   @id @default(cuid())
  pincode     String   @unique
  city        String
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  areaName    String
  image       String?
  slug        String   @unique
}
